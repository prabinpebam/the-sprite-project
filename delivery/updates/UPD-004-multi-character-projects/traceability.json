    {
      "id": "OUT-UPD004-FOLDERS",
      "status": "excluded",
      "expectation": "Organize characters with folders, tags, search, or reorder",
      "reason": "A bounded flat cast proves identity and isolation first",
      "consequence": "Stable creation order only",
      "disposition": "Future collection organization update"
    },
    {
      "id": "OUT-UPD004-BATCH-EXPORT",
      "status": "excluded",
      "expectation": "Export every character in one command",
      "reason": "Batch naming, partial failure, and destination collision are separate delivery semantics",
      "consequence": "Switch and export active character",
      "disposition": "Future delivery automation"
    },
    {
      "id": "OUT-UPD004-SCENES",
      "status": "excluded",
      "expectation": "Place several characters together with terrain",
      "reason": "Collection ownership does not define scene transforms or runtime composition",
      "consequence": "Independent previews/exports",
      "disposition": "Scene stage"
    },
    {
      "id": "OUT-UPD004-PER-CHARACTER-THEME",
      "status": "excluded",
      "expectation": "Give each character a complete independent project theme",
      "reason": "Existing project theme plus recipe overrides already provides coherent shared mood and local exceptions",
      "consequence": "Theme shared; overrides local",
      "disposition": "Revisit with measured need"
    },
    {
      "id": "OUT-UPD004-IMPORT-MERGE",
      "status": "excluded",
      "expectation": "Import or merge one recipe from another project",
      "reason": "Pack-lock and identity collision resolution requires a distinct transfer contract",
      "consequence": "Whole-project archive transfer only",
      "disposition": "Future recipe transfer update"
    },
    {
      "id": "OUT-UPD004-COLLABORATION",
      "status": "excluded",
      "expectation": "Cloud sync or concurrent collaborative character editing",
      "reason": "Product remains local-first and zero-server",
      "consequence": "Existing local conflict choices",
      "disposition": "Not in current local-first roadmap"
    },
    {
      "id": "OUT-UPD004-DRAG-DROP",
      "status": "excluded",
      "expectation": "Drag characters to reorder or group",
      "reason": "Order has no gameplay/export meaning in this update",
      "consequence": "Creation order is fixed",
      "disposition": "Collection organization update"
    },
    {
      "id": "OUT-UPD004-UNBOUNDED",
      "status": "excluded",
      "expectation": "Create unlimited characters",
      "reason": "A 16-recipe bound keeps UI, save, archive, and performance categorical",
      "consequence": "Seventeenth creation is blocked",
      "disposition": "Increase only from measured capacity evidence"
    }
